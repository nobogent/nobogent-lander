---
import '../styles/global.css';
import { Image } from 'astro:assets';
import logoTransparent from '../assets/logo-transparent.png';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/logo-transparent.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
    <title>Privacy Policy - Nobogent AI</title>
    <meta name="description" content="Privacy Policy for Nobogent AI marketing automation suite." />
    
    <!-- Font & Asset Optimization (PageSpeed Optimized) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://fonts.cdnfonts.com" crossorigin />
    <link rel="preload" href={logoTransparent.src} as="image" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.cdnfonts.com/css/geist-sans" rel="stylesheet" />

    <!-- Consent Management script (GDPR/CCPA/ePrivacy Compliant) -->
    <script is:inline>
      (function() {
        var storageKey = 'nobogent_cookie_consent';
        
        function loadTracking() {
          // 1. Load Meta Pixel
          if (!window.fbq) {
            !function(f,b,e,v,n,t,s)
            {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
            n.callMethod.apply(n,arguments):n.queue.push(arguments)};
            if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
            n.queue=[];t=b.createElement(e);t.async=!0;
            t.src=v;s=b.getElementsByTagName(e)[0];
            s.parentNode.insertBefore(t,s)}(window, document,'script',
            'https://connect.facebook.net/en_US/fbevents.js');
            fbq('init', '1684055349552829');
            fbq('track', 'PageView');
          }
          
          // 2. Load Google Tag Manager
          if (!window.dataLayer) {
            (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
            new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
            j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
            'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
            })(window,document,'script','dataLayer','GTM-W79WBBRP');
          }
        }
        
        window.nobogentAcceptConsent = function() {
          try {
            localStorage.setItem(storageKey, 'accepted');
          } catch(e) {}
          loadTracking();
        };

        window.nobogentDeclineConsent = function() {
          try {
            localStorage.setItem(storageKey, 'declined');
          } catch(e) {}
        };
        
        var consent = null;
        try {
          consent = localStorage.getItem(storageKey);
        } catch(e) {}
        
        if (consent === 'accepted') {
          window.addEventListener('load', function() {
            setTimeout(loadTracking, 1500);
          });
        } else if (consent !== 'declined') {
          window.addEventListener('DOMContentLoaded', function() {
            var banner = document.getElementById('cookieConsentBanner');
            var acceptBtn = document.getElementById('acceptCookies');
            var declineBtn = document.getElementById('declineCookies');
            
            if (banner) {
              setTimeout(function() {
                banner.classList.add('show');
              }, 1200);
            }
            
            if (acceptBtn) {
              acceptBtn.addEventListener('click', function() {
                window.nobogentAcceptConsent();
                if (banner) banner.classList.remove('show');
              });
            }
            
            if (declineBtn) {
              declineBtn.addEventListener('click', function() {
                window.nobogentDeclineConsent();
                if (banner) banner.classList.remove('show');
              });
            }
          });
        }
      })();
    </script>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W79WBBRP"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <noscript>
      <img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=1684055349552829&ev=PageView&noscript=1" />
    </noscript>
    <!-- End Google Tag Manager (noscript) -->

    <!-- Cookie Consent Banner -->
    <div id="cookieConsentBanner" class="cookie-banner">
      <p>
        We use cookies to optimize site experience, analyze analytics traffic, and personalize ads. You can accept or decline non-essential cookies. Read our <a href="/privacy-policy">Privacy Policy</a> to learn more.
      </p>
      <div class="cookie-banner-actions">
        <button id="declineCookies" class="cookie-btn cookie-btn-decline">Decline</button>
        <button id="acceptCookies" class="cookie-btn cookie-btn-accept">Accept All</button>
      </div>
    </div>

    <!-- Header Navigation -->
    <header class="header-nav">
      <div class="container header-container">
        <a href="/" style="display: flex; align-items: center; justify-content: center; height: 100%;">
          <Image src={logoTransparent} alt="Nobogent Logo" width={180} height={60} style="height: 60px; width: auto; object-fit: contain;" />
        </a>
        <div>
          <a href="/" class="btn btn-secondary" style="padding: var(--spacing-xxs) var(--spacing-md); font-size: 13px;">&larr; Back to Home</a>
        </div>
      </div>
    </header>

    <main style="padding: var(--spacing-5xl) 0; position: relative;">
      <div class="mesh-bg" style="opacity: 0.3; height: 400px;"></div>
      <div class="container" style="max-width: 800px;">
        <h1 class="display-lg" style="margin-bottom: var(--spacing-xl); text-align: left;">Privacy Policy</h1>
        
        <div style="display: flex; flex-direction: column; gap: var(--spacing-lg); line-height: 1.7; color: var(--color-body); font-size: 15px;">
          <p><em>Last updated: June 30, 2026</em></p>
          
          <p>At Nobogent, we prioritize the privacy and security of our users' data. This Privacy Policy describes how we collect, use, and disclose information when you visit or use our platform, including our Meta Conversions API (CAPI) integrations, lead-capture forms, and ad generation tools.</p>
          
          <h2 style="font-size: 20px; color: var(--color-ink); margin-top: var(--spacing-md);">1. Information We Collect</h2>
          <p>We collect information you provide directly to us when filling out our qualification form, setting up your account, or communicating with us. This includes:</p>
          <ul style="padding-left: var(--spacing-lg);">
            <li>Contact details such as your name, work email address, and phone number.</li>
            <li>Marketing and advertising data, including your monthly advertising budget and launch timelines.</li>
            <li>Integration details, such as Meta Pixel identifiers necessary to configure server-side CAPI integrations.</li>
          </ul>
          
          <h2 style="font-size: 20px; color: var(--color-ink); margin-top: var(--spacing-md);">2. How We Use Your Information</h2>
          <p>We use the collected information for the following purposes:</p>
          <ul style="padding-left: var(--spacing-lg);">
            <li>To construct and configure your customized AI marketing CRM environment.</li>
            <li>To optimize your server-side Meta Conversions API (CAPI) settings and help bypass browser tracking blocks.</li>
            <li>To contact you regarding your qualification application and schedule consultations.</li>
            <li>To monitor, analyze, and improve the user experience and speed of our website.</li>
          </ul>

          <h2 style="font-size: 20px; color: var(--color-ink); margin-top: var(--spacing-md);">3. Meta Conversions API (CAPI) Data Policy</h2>
          <p>When deploying server-side CAPI integrations for your campaigns, Nobogent serves strictly as a data processor. All end-user conversion events transmitted through your server integrations are governed by your own company's privacy policy and Meta's Business Tools Terms. We do not store, sell, or rent your customers' transactional or personal data for any purpose.</p>

          <h2 style="font-size: 20px; color: var(--color-ink); margin-top: var(--spacing-md);">4. Data Retention and Security</h2>
          <p>We implement strict administrative, technical, and physical security measures to safeguard your credentials and campaign details. Data is retained only for as long as necessary to provide you with active marketing automation services.</p>

          <h2 style="font-size: 20px; color: var(--color-ink); margin-top: var(--spacing-md);">5. Contact Us</h2>
          <p>If you have any questions or concerns about this Privacy Policy, please reach out to us at <a href="mailto:support@nobogent.com" style="color: var(--color-link); text-decoration: underline;">support@nobogent.com</a>.</p>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer style="padding: var(--spacing-4xl) 0 var(--spacing-2xl); background-color: var(--color-canvas); font-size: 12px; border-top: 1px solid var(--color-hairline);">
      <div class="container" style="display: flex; flex-direction: column; gap: var(--spacing-xl);">
        <div style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: var(--spacing-lg);">
          <div>
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: var(--spacing-xs);">
              <Image src={logoTransparent} alt="Nobogent Logo" width={192} height={64} style="height: 64px; width: auto; object-fit: contain;" />
            </div>
            <p style="color: var(--color-mute); max-width: 250px;">Bypass cookie blocks, auto-design ad layouts, and deploy Meta Conversion CRM engines on autopilot.</p>
          </div>
          <div>
            <h4 style="font-size: 11px; font-weight: 600; color: var(--color-ink); margin-bottom: var(--spacing-sm); text-transform: uppercase;" class="mono-label">Legal</h4>
            <p style="color: var(--color-mute); font-size: 11px;">Powered by ADROLLS AI Business Solutions</p>
          </div>
        </div>
        <div style="border-top: 1px solid var(--color-hairline); padding-top: var(--spacing-lg); display: flex; justify-content: space-between; flex-wrap: wrap; color: var(--color-mute);">
          <p>© {new Date().getFullYear()} Nobogent. All rights reserved.</p>
          <div style="display: flex; gap: var(--spacing-md);">
            <a href="/">Home</a>
            <a href="/terms-of-service">Terms of Service</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
