---
import '../styles/global.css';
import { Image } from 'astro:assets';
import logoTransparent from '../assets/logo-transparent.png';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/logo-transparent.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
    <title>Terms of Service - Nobogent AI</title>
    <meta name="description" content="Terms of Service for Nobogent AI marketing automation suite." />
    
    <!-- Font & Asset Optimization (PageSpeed Optimized) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://fonts.cdnfonts.com" crossorigin />
    <link rel="preload" href={logoTransparent.src} as="image" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.cdnfonts.com/css/geist-sans" rel="stylesheet" />

    <!-- Consent Management script (GDPR/CCPA/ePrivacy Compliant) -->
    <script is:inline>
      (function() {
        var storageKey = 'nobogent_cookie_consent';
        
        function loadTracking() {
          // 1. Load Meta Pixel
          if (!window.fbq) {
            !function(f,b,e,v,n,t,s)
            {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
            n.callMethod.apply(n,arguments):n.queue.push(arguments)};
            if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
            n.queue=[];t=b.createElement(e);t.async=!0;
            t.src=v;s=b.getElementsByTagName(e)[0];
            s.parentNode.insertBefore(t,s)}(window, document,'script',
            'https://connect.facebook.net/en_US/fbevents.js');
            fbq('init', '1684055349552829');
            fbq('track', 'PageView');
          }
          
          // 2. Load Google Tag Manager
          if (!window.dataLayer) {
            (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
            new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
            j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
            'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
            })(window,document,'script','dataLayer','GTM-W79WBBRP');
          }
        }
        
        window.nobogentAcceptConsent = function() {
          try {
            localStorage.setItem(storageKey, 'accepted');
          } catch(e) {}
          loadTracking();
        };

        window.nobogentDeclineConsent = function() {
          try {
            localStorage.setItem(storageKey, 'declined');
          } catch(e) {}
        };
        
        var consent = null;
        try {
          consent = localStorage.getItem(storageKey);
        } catch(e) {}
        
        if (consent === 'accepted') {
          window.addEventListener('load', function() {
            setTimeout(loadTracking, 1500);
          });
        } else if (consent !== 'declined') {
          window.addEventListener('DOMContentLoaded', function() {
            var banner = document.getElementById('cookieConsentBanner');
            var acceptBtn = document.getElementById('acceptCookies');
            var declineBtn = document.getElementById('declineCookies');
            
            if (banner) {
              setTimeout(function() {
                banner.classList.add('show');
              }, 1200);
            }
            
            if (acceptBtn) {
              acceptBtn.addEventListener('click', function() {
                window.nobogentAcceptConsent();
                if (banner) banner.classList.remove('show');
              });
            }
            
            if (declineBtn) {
              declineBtn.addEventListener('click', function() {
                window.nobogentDeclineConsent();
                if (banner) banner.classList.remove('show');
              });
            }
          });
        }
      })();
    </script>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W79WBBRP"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <noscript>
      <img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=1684055349552829&ev=PageView&noscript=1" />
    </noscript>
    <!-- End Google Tag Manager (noscript) -->

    <!-- Cookie Consent Banner -->
    <div id="cookieConsentBanner" class="cookie-banner">
      <p>
        We use cookies to optimize site experience, analyze analytics traffic, and personalize ads. You can accept or decline non-essential cookies. Read our <a href="/privacy-policy">Privacy Policy</a> to learn more.
      </p>
      <div class="cookie-banner-actions">
        <button id="declineCookies" class="cookie-btn cookie-btn-decline">Decline</button>
        <button id="acceptCookies" class="cookie-btn cookie-btn-accept">Accept All</button>
      </div>
    </div>

    <!-- Header Navigation -->
    <header class="header-nav">
      <div class="container header-container">
        <a href="/" style="display: flex; align-items: center; justify-content: center; height: 100%;">
          <Image src={logoTransparent} alt="Nobogent Logo" width={270} style="height: 90px; width: auto; object-fit: contain;" />
        </a>
        <div>
          <a href="/" class="btn btn-secondary" style="padding: var(--spacing-xxs) var(--spacing-md); font-size: 13px;">&larr; Back to Home</a>
        </div>
      </div>
    </header>

    <main style="padding: var(--spacing-5xl) 0; position: relative;">
      <div class="mesh-bg" style="opacity: 0.3; height: 400px;"></div>
      <div class="container" style="max-width: 800px;">
        <h1 class="display-lg" style="margin-bottom: var(--spacing-xl); text-align: left;">Terms of Service</h1>
        
        <div style="display: flex; flex-direction: column; gap: var(--spacing-lg); line-height: 1.7; color: var(--color-body); font-size: 15px;">
          <p><em>Last updated: June 30, 2026</em></p>
          
          <p>Welcome to Nobogent (nobogent.com). By using our website, platform services, or automation tools, you agree to comply with and be bound by the following Terms of Service. Please read these terms carefully before accessing our system.</p>
          
          <h2 style="font-size: 20px; color: var(--color-ink); margin-top: var(--spacing-md);">1. Terms Agreement</h2>
          <p>By filling out our budget eligibility wizard, registering an account, or deploying our tracking servers, you signify your acceptance of these Terms of Service. If you do not agree to these terms, please do not use our services.</p>
          
          <h2 style="font-size: 20px; color: var(--color-ink); margin-top: var(--spacing-md);">2. Scope of Service</h2>
          <p>Nobogent provides an AI-integrated marketing employee infrastructure. Features include automated ad copy generation, media template editing, and custom server-side Meta Conversions API (CAPI) hosting configurations. All CAPI server hosting deployments are maintained by **ADROLLS AI Business Solutions**.</p>
          
          <h2 style="font-size: 20px; color: var(--color-ink); margin-top: var(--spacing-md);">3. User Responsibility & Compliance</h2>
          <p>You agree to use the Nobogent platform only for lawful advertising purposes. You represent and warrant that:</p>
          <ul style="padding-left: var(--spacing-lg);">
            <li>All budget and identity information supplied in our forms is true and correct.</li>
            <li>You will maintain strict compliance with Meta's Advertising Policies and local consumer privacy regulations (such as CCPA or GDPR) regarding customer tracking.</li>
            <li>You will not use the AI creative generation engine to construct misleading, deceptive, or infringing advertising media.</li>
          </ul>

          <h2 style="font-size: 20px; color: var(--color-ink); margin-top: var(--spacing-md);">4. Subscriptions and Payments</h2>
          <p>Nobogent is billed on a monthly subscription model (standard at ₹9,999 / $199 per month). Subscriptions auto-renew unless cancelled. Server infrastructure allocations remain active only during paid service durations.</p>

          <h2 style="font-size: 20px; color: var(--color-ink); margin-top: var(--spacing-md);">5. Limitation of Liability</h2>
          <p>Nobogent and its operator (ADROLLS AI Business Solutions) shall not be liable for any indirect, incidental, or consequential damages resulting from ad account suspensions, fluctuating advertising campaign performances, or server tracking outages.</p>

          <h2 style="font-size: 20px; color: var(--color-ink); margin-top: var(--spacing-md);">6. Modifications to Terms</h2>
          <p>We reserve the right to modify these Terms of Service at any time. Changes will be posted to this page with an updated revision date. Continued usage of Nobogent following modifications constitutes your acceptance of the revised terms.</p>

          <h2 style="font-size: 20px; color: var(--color-ink); margin-top: var(--spacing-md);">7. Contact</h2>
          <p>For support or licensing inquiries under these terms, please contact <a href="mailto:legal@nobogent.com" style="color: var(--color-link); text-decoration: underline;">legal@nobogent.com</a>.</p>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer style="padding: var(--spacing-4xl) 0 var(--spacing-2xl); background-color: var(--color-canvas); font-size: 12px; border-top: 1px solid var(--color-hairline);">
      <div class="container" style="display: flex; flex-direction: column; gap: var(--spacing-xl);">
        <div style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: var(--spacing-lg);">
          <div>
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: var(--spacing-xs);">
              <Image src={logoTransparent} alt="Nobogent Logo" width={288} style="height: 96px; width: auto; object-fit: contain;" />
            </div>
            <p style="color: var(--color-mute); max-width: 250px;">Bypass cookie blocks, auto-design ad layouts, and deploy Meta Conversion CRM engines on autopilot.</p>
          </div>
          <div>
            <h4 style="font-size: 11px; font-weight: 600; color: var(--color-ink); margin-bottom: var(--spacing-sm); text-transform: uppercase;" class="mono-label">Legal</h4>
            <p style="color: var(--color-mute); font-size: 11px;">Powered by ADROLLS AI Business Solutions</p>
          </div>
        </div>
        <div style="border-top: 1px solid var(--color-hairline); padding-top: var(--spacing-lg); display: flex; justify-content: space-between; flex-wrap: wrap; color: var(--color-mute);">
          <p>© {new Date().getFullYear()} Nobogent. All rights reserved.</p>
          <div style="display: flex; gap: var(--spacing-md);">
            <a href="/">Home</a>
            <a href="/privacy-policy">Privacy Policy</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
