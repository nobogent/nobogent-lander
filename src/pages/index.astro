    <!-- Interactive Qualification Wizard Script -->
    <script>
      // DOM elements
      const btnNext1 = document.getElementById('btn-next-1');
      const btnNext2 = document.getElementById('btn-next-2');
      const btnPrev2 = document.getElementById('btn-prev-2');
      const btnPrev3 = document.getElementById('btn-prev-3');

      const stepContent1 = document.getElementById('step-content-1');
      const stepContent2 = document.getElementById('step-content-2');
      const stepContent3 = document.getElementById('step-content-3');
      const stepContentSuccess = document.getElementById('step-content-success');

      const stepDot1 = document.getElementById('step-dot-1');
      const stepDot2 = document.getElementById('step-dot-2');
      const stepDot3 = document.getElementById('step-dot-3');

      const detailsForm = document.getElementById('details-form');

      // Select option toggles
      const budgetButtons = document.querySelectorAll('.budget-opt');
      budgetButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          budgetButtons.forEach(b => b.classList.remove('selected'));
          btn.classList.add('selected');
        });
      });

      const timeButtons = document.querySelectorAll('.time-opt');
      timeButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          timeButtons.forEach(b => b.classList.remove('selected'));
          btn.classList.add('selected');
        });
      });

      // Wizard Nav transitions
      btnNext1.addEventListener('click', () => {
        stepContent1.style.display = 'none';
        stepContent2.style.display = 'block';
        stepDot2.classList.add('active');
        stepDot1.classList.add('completed');
      });

      btnPrev2.addEventListener('click', () => {
        stepContent2.style.display = 'none';
        stepContent1.style.display = 'block';
        stepDot2.classList.remove('active');
        stepDot1.classList.remove('completed');
      });

      btnNext2.addEventListener('click', () => {
        stepContent2.style.display = 'none';
        stepContent3.style.display = 'block';
        stepDot3.classList.add('active');
        stepDot2.classList.add('completed');
      });

      btnPrev3.addEventListener('click', () => {
        stepContent3.style.display = 'none';
        stepContent2.style.display = 'block';
        stepDot3.classList.remove('active');
        stepDot2.classList.remove('completed');
      });

      detailsForm.addEventListener('submit', (e) => {
        e.preventDefault();
        stepContent3.style.display = 'none';
        stepContentSuccess.style.display = 'block';
        stepDot3.classList.add('completed');
      });
    </script>
